@font-face {
    font-family: "{{ name }}";
    src: url("./fonts/icon-font.woff2") format("woff2");
    {{!-- src: {{{ fontSrc }}}; --}}
}

{{# if selector }}
{{ selector }}:before {
{{ else }}
[class^="{{prefix}}-"]:before, [class*=" {{prefix}}-"]:before {
{{/ if }}
    font-family: {{ name }} !important;
    font-style: normal;
    font-weight: normal !important;
    font-variant: normal;
    text-transform: none;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

{{# each codepoints }}
{{# if ../selector }}
{{ ../selector }}.{{ ../prefix }}-{{ @key }}:before {
{{ else }}
{{ tag }}.{{ ../prefix }}-{{ @key }}:before {
{{/ if }}
    content: "\\{{ codepoint this }}";
}
{{/ each }}
